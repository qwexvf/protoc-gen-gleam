) -> Result(#(ScanLogEventAcc, BitArray), wire.DecodeError) {
  case field_number {
    n if n == field_scan_log_event_level ->
      case wire.decode_varint(rest) {
        Error(e) -> Error(e)
        Ok(#(v, r)) ->
          case log_level_from_int(v) {
            Error(e) -> Error(e)
            Ok(ev) -> Ok(#(ScanLogEventAcc(..acc, level: ev), r))
          }
      }
    n if n == field_scan_log_event_message ->
      case wire.decode_len_delimited(rest) {
        Error(e) -> Error(e)
        Ok(#(bytes, r)) ->
          case wire.decode_string(bytes) {
            Error(e) -> Error(e)
            Ok(s) -> Ok(#(ScanLogEventAcc(..acc, message: s), r))
          }
      }
    n if n == field_scan_log_event_phase ->
      case wire.decode_len_delimited(rest) {
        Error(e) -> Error(e)
        Ok(#(bytes, r)) ->
          case wire.decode_string(bytes) {
            Error(e) -> Error(e)
            Ok(s) -> Ok(#(ScanLogEventAcc(..acc, phase: s), r))
          }
      }
    _ ->
      case wire.skip_field(rest, wire_type) {
        Ok(r) -> Ok(#(acc, r))
        Error(e) -> Error(e)
      }
  }
}

