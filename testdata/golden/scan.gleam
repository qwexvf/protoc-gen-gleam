// --- Shared decode helpers -------------------------------------------

fn decode_fields(
  buf: BitArray,
  acc: a,
  handler: fn(Int, Int, BitArray, a) ->
    Result(#(a, BitArray), wire.DecodeError),
) -> Result(a, wire.DecodeError) {
  case buf {
    <<>> -> Ok(acc)
    _ ->
      case wire.decode_tag(buf) {
        Error(e) -> Error(e)
        Ok(#(field_number, wire_type, rest)) ->
          case handler(field_number, wire_type, rest, acc) {
            Error(e) -> Error(e)
            Ok(#(new_acc, new_rest)) ->
              decode_fields(new_rest, new_acc, handler)
          }
      }
  }
}

